<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Regression Suite">

    <test name="Regression Tests">

        <groups>
            <run>
                <include name="regression"/>

            </run>

        </groups>

        <classes>
            <class name="Tests.LoginPageTests"/>
            <class name="Tests.MyAccountPageTests"/>
            <class name="Tests.HomePageTests"/>
            <class name="Tests.ProductPageTests"/>
            <class name="Tests.CartPageTests"/>
            <class name="Tests.CheckoutPageTests"/>
            <class name="Tests.PaymentPageTests"/>

        </classes>

    </test>

</suite>